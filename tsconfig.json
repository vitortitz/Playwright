{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": [
        "src/pages/*"
      ],
      "@api/*": [
        "src/api/*"
      ],
      "@fixtures/*": [
        "src/fixtures/*"
      ],
      "@data/*": [
        "src/data/*"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}